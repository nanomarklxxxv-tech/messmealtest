# FIREBASE CONFIGURATION (Client-side - safe to expose)
# These values are restricted in Firebase Console to your domain
# Get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# THIRD-PARTY API KEYS (Public/Restricted APIs)
# Get from respective services
VITE_CALORIE_NINJAS_API_KEY=your_api_key_here

# EMAILJS CONFIGURATION (Client-side)
# Get from EmailJS Dashboard
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_TEMPLATE_ADD_ADMIN=template_id_add_admin
VITE_EMAILJS_TEMPLATE_TRANSFER_OWNERSHIP=template_id_transfer

# GMAIL NOTIFICATION ACCOUNT (Server-side only - DO NOT USE IN PRODUCTION)
# ⚠️  SECURITY WARNING: Never use production credentials here
# Use environment variables or secrets manager in production
# Set up Gmail App Password here for development only
EMAIL_USER=development@gmail.com
EMAIL_APP_PASSWORD=your_app_password_here

# FIREBASE ADMIN SDK (Server-side only - SECRET)
# ⚠️  CRITICAL: This contains your private key
# NEVER commit this to version control
# Store in environment variables or secrets manager only
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# PRODUCTION DEPLOYMENT
# NODE_ENV is set automatically by Vercel/deployment platform
NODE_ENV=development
