rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /artifacts/{appId}/users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && (request.auth.uid == userId 
            || get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
    }

    match /artifacts/{appId}/public/data/menus/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'faculty'];
    }

    match /artifacts/{appId}/public/data/mess_closures/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'faculty'];
    }

    match /artifacts/{appId}/public/data/ratings/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    match /artifacts/{appId}/public/data/proofs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    match /artifacts/{appId}/public/data/notices/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'faculty'];
    }

    match /artifacts/{appId}/public/data/feedback_reports/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    match /artifacts/{appId}/config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    match /artifacts/{appId}/mail_queue/{docId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    match /artifacts/{appId}/public/data/checklists/{docId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'student', 'faculty'];
      allow write: if request.auth != null
        && (get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']
            || get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.committeeRole != null);
    }

    match /artifacts/{appId}/public/data/checklist_reports/{docId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }
  }
}
