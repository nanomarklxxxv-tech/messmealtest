rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userRole(appId) {
      return get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.role;
    }

    function isAdmin(appId) {
      return userRole(appId) in ['super_admin', 'admin', 'mini_admin'];
    }

    function canEditHostel(appId) {
      let currentUser = get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid));
      let userRoleVal = currentUser.data.get('role', null);
      let hostelLockedAt = currentUser.data.get('hostelLockedAt', null);
      // Allow if super_admin OR hostel is not locked
      return userRoleVal == 'super_admin' || hostelLockedAt == null;
    }

    function isMiniAdmin(appId) {
      return userRole(appId) == 'mini_admin';
    }

    function miniAdminHostels(appId) {
      return get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.assignedHostels;
    }

    function miniAdminAllowed(appId, hostel) {
      return isMiniAdmin(appId) &&
        hostel in miniAdminHostels(appId);
    }

    function isStudentEmail() {
      return request.auth.token.email.matches('.*@vitapstudent\\.ac\\.in$');
    }

    function isFacultyEmail() {
      return request.auth.token.email.matches('.*@vitap\\.ac\\.in$') ||
        request.auth.token.email.matches('.*@vit\\.ac\\.in$');
    }

    match /artifacts/{appId}/users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        isAdmin(appId) ||
        (
          request.auth.uid == userId &&
          (
            (
              resource == null &&
              request.resource.data.keys().hasOnly([
                'email', 'name', 'role', 'approved', 'adminApproved', 'createdAt'
              ])
            ) ||
            (
              resource != null &&
              (
                (
                  request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                    'name', 'registrationId', 'hostel', 'messType', 'fcmToken',
                    'avatar', 'bio', 'lastSeenAt', 'updatedAt', 'studyingYear',
                    'lastActive', 'isOnline', 'email'
                  ]) &&
                  !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                    'role', 'approved', 'adminApproved', 'assignedHostels', 'committeeRole',
                    'hostelLockedAt', 'hostelLockedReason', 'assignedCommitteeHostel',
                    'assignedCommitteeHostelAt', 'adminRequested', 'adminApprovedAt',
                    'adminAddedBy', 'adminAddedAt'
                  ]) &&
                  (canEditHostel(appId) || resource.data.get('hostel', null) == null || request.resource.data.hostel == resource.data.get('hostel', null))
                ) ||
                (
                  resource.data.role == null &&
                  request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'approved']) &&
                  ((isStudentEmail() && request.resource.data.role == 'student') ||
                   (isFacultyEmail() && request.resource.data.role == 'faculty'))
                )
              )
            )
          )
        ) ||
        (
          isMiniAdmin(appId) &&
          resource.data.hostel in miniAdminHostels(appId) &&
          resource.data.role == 'student' &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role', 'adminApproved', 'approved', 'assignedHostels',
            'committeeRole', 'hostelLockedAt', 'hostelLockedReason',
            'assignedCommitteeHostel', 'assignedCommitteeHostelAt'
          ])
        )
      );
    }

    match /artifacts/{appId}/public/data/menus/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && isAdmin(appId);
    }

    match /artifacts/{appId}/public/data/mess_closures/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && isAdmin(appId);
    }

    match /artifacts/{appId}/public/data/ratings/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (isAdmin(appId) ||
          miniAdminAllowed(appId,
            resource.data.hostel));
    }

    match /artifacts/{appId}/public/data/proofs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (isAdmin(appId) ||
          miniAdminAllowed(appId,
            resource.data.hostel));
    }

    match /artifacts/{appId}/public/data/notices/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (isAdmin(appId) || isMiniAdmin(appId));
    }

    match /artifacts/{appId}/public/data/feedback_reports/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (isAdmin(appId) ||
          miniAdminAllowed(appId,
            resource.data.hostel));
    }

    match /artifacts/{appId}/config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && isAdmin(appId);
    }

    match /artifacts/{appId}/mail_queue/{docId} {
      allow read, write: if request.auth != null
        && isAdmin(appId);
    }

    match /artifacts/{appId}/public/data/checklists/{docId} {
      allow read: if request.auth != null
        && (isAdmin(appId)
          || get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.committeeRole != null);

      // Allow committee members to create checklist docs used by autosave.
      allow create: if request.auth != null
        && (isAdmin(appId)
          || (get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.committeeRole != null
            && get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.approved == true));

      // Committee members can update checklist items (status, remarks, etc.)
      // but cannot modify sensitive identity fields.
      allow update: if request.auth != null
        && (isAdmin(appId)
          || (get(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid)).data.committeeRole != null
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['hostel', 'role', 'committeeRole'])));

      allow delete: if request.auth != null && isAdmin(appId);
    }

    match /artifacts/{appId}/public/data/checklist_reports/{docId} {
      allow read, write: if request.auth != null
        && (isAdmin(appId) || isMiniAdmin(appId));
    }

    // Audit logs for tracking role changes and sensitive actions
    match /artifacts/{appId}/audit_logs/{logId} {
      allow read: if request.auth != null && isAdmin(appId);
      allow write: if request.auth != null && isAdmin(appId);
      allow create: if request.auth != null && isAdmin(appId);
    }
  }
}
